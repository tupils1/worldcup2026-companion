# Copy to configs/secrets.env (gitignored) and fill in.

# The Odds API — https://the-odds-api.com/
ODDS_API_KEY=

# API-Football (api-sports.io) — https://www.api-football.com/
API_FOOTBALL_KEY=

# Optional: FBref / Transfermarkt are scraped, no key needed.
# Optional: SportMonks fallback if API-Football coverage gaps
SPORTMONKS_KEY=

# DeepSeek API for LLM-based news scoring (replaces keyword classifier)
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat  # or deepseek-reasoner for better quality (slower/pricier)
